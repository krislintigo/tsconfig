{
  "name": "@krislintigo/tsconfig",
  "version": "1.0.0",
  "description": "Shared TypeScript configuration presets.",
  "type": "module",
  "files": [
    "tsconfig.base.json",
    "tsconfig.node.json",
    "nuxt.d.ts",
    "nuxt.js",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    "./base": "./tsconfig.base.json",
    "./base.json": "./tsconfig.base.json",
    "./node": "./tsconfig.node.json",
    "./node.json": "./tsconfig.node.json",
    "./nuxt": {
      "default": "./nuxt.js",
      "types": "./nuxt.d.ts"
    },
    "./nuxt.js": {
      "default": "./nuxt.js",
      "types": "./nuxt.d.ts"
    }
  }
}
